TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
BOT_NAME=Discord Handler
PREFIX=$
OWNER_IDS=your_id_here
ERROR_WEBHOOK=your_webhook_url_here
SLASH_COMMAND_WEBHOOK=your_webhook_url_here
PREFIX_COMMAND_WEBHOOK=your_webhook_url_here
JOIN_GUILD_WEBHOOK=your_webhook_url_here
LEAVE_GUILD_WEBHOOK=your_webhook_url_here
READY_WEBHOOK=your_webhook_url_here

# Database configuration
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite
# For PostgreSQL / MySQL / MariaDB / MSSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=discord_bot
